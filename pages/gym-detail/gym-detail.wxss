.page {
  background:
    radial-gradient(circle at 8% 0%, rgba(196, 222, 252, 0.58), transparent 330rpx),
    radial-gradient(circle at 96% 14%, rgba(211, 244, 255, 0.58), transparent 300rpx),
    #e9edf3;
  box-sizing: border-box;
  min-height: 100vh;
  padding: 48rpx 36rpx 56rpx;
}

.hero,
.section,
.quick-actions {
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid #e0e6ee;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.07);
  overflow: hidden;
}

.hero {
  margin-top: 36rpx;
}

.hero-map {
  background:
    linear-gradient(#b9ddeb 2rpx, transparent 2rpx),
    linear-gradient(90deg, #b9ddeb 2rpx, transparent 2rpx),
    #e4f4fa;
  background-size: 132rpx 132rpx, 132rpx 132rpx, auto;
  height: 214rpx;
  position: relative;
}

.hero-map::after {
  background: rgba(0, 122, 255, 0.35);
  border-radius: 999rpx;
  content: "";
  height: 8rpx;
  left: 88rpx;
  position: absolute;
  right: 100rpx;
  top: 144rpx;
}

.hero-content {
  border-top: 1rpx solid #e0e6ee;
  padding: 28rpx;
}

.status-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.status {
  border: 1rpx solid transparent;
  border-radius: 20rpx;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
  padding: 10rpx 13rpx;
}

.status.verified {
  background: #e8f8ed;
  border-color: rgba(48, 200, 90, 0.22);
  color: #1f9a49;
}

.status.pending {
  background: #fff3e1;
  border-color: rgba(255, 138, 0, 0.22);
  color: #b66b00;
}

.status.new {
  background: #e5f2ff;
  border-color: rgba(0, 122, 255, 0.2);
  color: #007aff;
}

.status.warning {
  background: #ffe9e8;
  border-color: rgba(255, 69, 58, 0.2);
  color: #ff453a;
}

.confidence {
  color: #929cad;
  font-size: 22rpx;
  font-weight: 700;
}

.name {
  color: #101828;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.16;
  margin-top: 24rpx;
}

.meta,
.address {
  color: #5d6878;
  font-size: 24rpx;
  line-height: 1.45;
  margin-top: 10rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}

.tag {
  background: #f7f9fc;
  border: 1rpx solid #e0e6ee;
  border-radius: 20rpx;
  color: #5d6878;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
  padding: 9rpx 12rpx;
}

.search-command {
  align-items: center;
  background: rgba(251, 252, 254, 0.96);
  border: 1rpx solid rgba(216, 224, 234, 0.95);
  border-radius: 36rpx;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.12);
  display: grid;
  gap: 22rpx;
  grid-template-columns: 64rpx 1fr 88rpx;
  margin-top: 28rpx;
  min-height: 104rpx;
  padding: 18rpx 22rpx 18rpx 26rpx;
  position: relative;
}

.search-command::before {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  content: "";
  height: 1rpx;
  left: 28rpx;
  position: absolute;
  right: 28rpx;
  top: 1rpx;
}

.search-command::after {
  background: rgba(0, 122, 255, 0.18);
  border: 0;
  border-radius: 999rpx;
  bottom: 0;
  content: "";
  height: 1rpx;
  left: 36rpx;
  position: absolute;
  right: 36rpx;
}

.search-symbol {
  background: #f7f9fc;
  border: 1rpx solid #e2e8f0;
  border-radius: 50%;
  height: 64rpx;
  position: relative;
  width: 64rpx;
}

.search-symbol::before {
  border: 4rpx solid #5d6878;
  border-radius: 50%;
  content: "";
  height: 20rpx;
  left: 18rpx;
  position: absolute;
  top: 17rpx;
  width: 20rpx;
}

.search-symbol::after {
  background: #5d6878;
  border-radius: 4rpx;
  content: "";
  height: 4rpx;
  left: 40rpx;
  position: absolute;
  top: 43rpx;
  transform: rotate(45deg);
  width: 16rpx;
}

.search-copy {
  min-width: 0;
}

.search-main {
  color: #101828;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.2;
}

.search-sub {
  color: #929cad;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  margin-top: 6rpx;
}

.search-action {
  align-items: center;
  background: #f7f9fc;
  border: 1rpx solid #e2e8f0;
  border-radius: 28rpx;
  display: flex;
  height: 68rpx;
  justify-content: center;
  padding: 0;
  position: relative;
  width: 76rpx;
}

.search-action::before,
.search-action::after,
.search-action view {
  background: #007aff;
  border: 0;
  border-radius: 4rpx;
  content: "";
  height: 4rpx;
  position: absolute;
  width: 34rpx;
}

.search-action::before {
  top: 24rpx;
}

.search-action view {
  top: 44rpx;
}

.search-action::after {
  background: #ffffff;
  border: 4rpx solid #007aff;
  border-radius: 50%;
  height: 12rpx;
  left: 25rpx;
  top: 18rpx;
  width: 12rpx;
}

.quick-actions {
  display: grid;
  gap: 28rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 28rpx;
  padding: 88rpx 28rpx 28rpx;
  position: relative;
}

.quick-actions::before {
  color: #101828;
  content: "快速标记";
  font-size: 28rpx;
  font-weight: 800;
  left: 28rpx;
  position: absolute;
  top: 26rpx;
}

.action {
  background: #f7f9fc;
  border: 1rpx solid #e0e6ee;
  border-radius: 32rpx;
  color: #101828;
  min-height: 96rpx;
  padding: 22rpx;
  text-align: center;
}

.action:first-child,
.action.marked {
  background: #007aff;
  border-color: #007aff;
  box-shadow: 0 0 38rpx rgba(0, 122, 255, 0.2);
  color: #ffffff;
}

.action::after,
.date-cell::after,
.secondary::after {
  border: 0;
}

.action-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.action-count {
  color: #5d6878;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
  margin-top: 8rpx;
}

.action:first-child .action-count,
.action.marked .action-count {
  color: rgba(255, 255, 255, 0.78);
}

.section {
  margin-top: 28rpx;
  padding: 28rpx;
}

.section-title {
  color: #101828;
  font-size: 32rpx;
  font-weight: 800;
}

.section-sub {
  color: #5d6878;
  font-size: 22rpx;
  line-height: 1.4;
  margin-top: 8rpx;
}

.calendar {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(4, 1fr);
  margin-top: 24rpx;
}

.date-cell {
  background: #f7f9fc;
  border: 1rpx solid #e0e6ee;
  border-radius: 28rpx;
  color: #101828;
  min-height: 136rpx;
  padding: 14rpx 6rpx;
  text-align: center;
}

.date-cell.marked {
  background: #007aff;
  border-color: #007aff;
  color: #ffffff;
}

.date-label {
  color: #929cad;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.2;
}

.date-cell.marked .date-label {
  color: rgba(255, 255, 255, 0.75);
}

.date-day {
  font-size: 35rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-top: 7rpx;
}

.date-count {
  color: #5d6878;
  display: inline-block;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  margin-top: 9rpx;
}

.date-cell.calm {
  background: #e8f8ed;
}

.date-cell.warm,
.date-cell.hot {
  background: #fff3e1;
}

.date-cell.calm .date-count {
  color: #30c85a;
}

.date-cell.warm .date-count,
.date-cell.hot .date-count {
  color: #ff8a00;
}

.date-cell.marked .date-count {
  color: #ffffff;
}

.info-row {
  align-items: center;
  border-bottom: 1rpx solid rgba(199, 208, 220, 0.72);
  display: flex;
  justify-content: space-between;
  min-height: 76rpx;
}

.info-label {
  color: #5d6878;
  font-size: 24rpx;
}

.info-value {
  color: #101828;
  font-size: 24rpx;
  font-weight: 700;
}

.facility-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 22rpx;
}

.facility {
  background: #f7f9fc;
  border: 1rpx solid #e0e6ee;
  border-radius: 28rpx;
  color: #929cad;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 62rpx;
  text-align: center;
}

.facility.yes {
  background: #e8f8ed;
  border-color: rgba(48, 200, 90, 0.22);
  color: #1f9a49;
}

.bottom-actions {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 28rpx;
}

.secondary {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #e0e6ee;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.07);
  color: #101828;
  font-size: 28rpx;
  font-weight: 800;
  height: 88rpx;
  line-height: 86rpx;
}

.empty {
  align-items: center;
  background: #e9edf3;
  color: #5d6878;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  justify-content: center;
  min-height: 80vh;
}
